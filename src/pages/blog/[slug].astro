---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const readingTime = Math.max(1, Math.round((post.body?.split(/\s+/).length ?? 0) / 200));
---

<BaseLayout title={`${post.data.title} - AscendKyo.dev`} description={post.data.description}>
  <article class="px-6 py-24">
    <div class="mx-auto max-w-3xl">
      <a href="/blog/" class="flex items-center gap-1.5 text-sm text-muted transition-colors hover:text-text">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"></path></svg>
        Back to Blog
      </a>

      <header class="mt-8">
        <h1 class="text-3xl font-bold tracking-tight">{post.data.title}</h1>
        <div class="mt-4 flex flex-wrap items-center gap-3">
          <span class="mono text-sm text-muted">
            {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </span>
          <span class="text-muted">&middot;</span>
          <span class="mono text-sm text-muted">{readingTime} min read</span>
          <span class="badge">{post.data.category}</span>
        </div>
        <div class="mt-3 flex flex-wrap gap-2">
          {post.data.tags.map((tag: string) => (
            <span class="badge mono text-xs">{tag}</span>
          ))}
        </div>
      </header>

      <div class="prose-custom mt-10">
        <Content />
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .prose-custom :global(h2) {
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--color-text);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .prose-custom :global(h3) {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-text);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .prose-custom :global(p) {
    color: var(--color-muted);
    line-height: 1.75;
    margin-bottom: 1.25rem;
  }

  .prose-custom :global(ul),
  .prose-custom :global(ol) {
    color: var(--color-muted);
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .prose-custom :global(li) {
    margin-bottom: 0.375rem;
  }

  .prose-custom :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    background-color: var(--color-border);
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    color: var(--color-primary);
  }

  .prose-custom :global(pre) {
    background-color: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    padding: 1rem 1.25rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }

  .prose-custom :global(pre code) {
    background: none;
    padding: 0;
    color: var(--color-muted);
  }

  .prose-custom :global(strong) {
    color: var(--color-text);
    font-weight: 600;
  }

  .prose-custom :global(a) {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .prose-custom :global(a:hover) {
    color: var(--color-text);
  }

  .prose-custom :global(blockquote) {
    border-left: 3px solid var(--color-border);
    padding-left: 1rem;
    color: var(--color-muted);
    font-style: italic;
    margin-bottom: 1.25rem;
  }
</style>
