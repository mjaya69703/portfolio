---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const categories = [...new Set(posts.map((p) => p.data.category))].sort();
---

<BaseLayout title="Blog - AscendKyo.dev" description="Knowledge repository - articles about DevOps, Infrastructure, Linux, Docker, and more">
  <section class="px-6 py-24">
    <div class="mx-auto max-w-5xl">
      <h1 class="text-3xl font-bold tracking-tight">Blog</h1>
      <p class="mt-2 text-muted">What has been learned and how problems were solved</p>

      <!-- Categories -->
      <div class="mt-8 flex flex-wrap gap-2">
        <span class="badge badge-primary">All</span>
        {categories.map((cat) => (
          <span class="badge">{cat}</span>
        ))}
      </div>

      <!-- Posts -->
      <div class="mt-10 space-y-6">
        {posts.map((post) => {
          const readingTime = Math.max(1, Math.round(post.body?.split(/\s+/).length / 200));
          return (
            <a href={`/blog/${post.id}/`} class="card block">
              <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
                <div>
                  <h2 class="text-base font-semibold">{post.data.title}</h2>
                  <p class="mt-1.5 text-sm text-muted leading-relaxed">{post.data.description}</p>
                  <div class="mt-3 flex flex-wrap items-center gap-3">
                    <span class="mono text-xs text-muted">
                      {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                    </span>
                    <span class="text-xs text-border">&middot;</span>
                    <span class="mono text-xs text-muted">{readingTime} min read</span>
                    <span class="badge text-xs">{post.data.category}</span>
                  </div>
                </div>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-1 shrink-0 text-muted"><path d="m9 18 6-6-6-6"></path></svg>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>
</BaseLayout>
