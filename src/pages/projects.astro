---
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = [
  {
    name: 'NexaCampus',
    description: 'Comprehensive academic information system (SIAKAD PT) built with Laravel 12 & Livewire 4. Manages academics, learning, admissions, finance, student services, HR, and academic oversight in one platform.',
    technologies: ['Laravel', 'Livewire', 'Tailwind CSS', 'MySQL'],
    status: 'Active',
    github: 'https://github.com/mjaya69703/nexacampus',
    demo: 'https://nexacampus.idev-fun.org',
  },
  {
    name: 'Neco Siakad',
    description: 'Open-source academic system for higher education. Production-ready SIAKAD platform with 45+ stars and 15+ forks on GitHub.',
    technologies: ['Laravel', 'Blade', 'HTML', 'CSS'],
    status: 'Active',
    github: 'https://github.com/mjaya69703/siakad-pt.internal-dev.id',
    demo: 'https://siakad-pt.idev-fun.org',
  },
  {
    name: 'Arpotret',
    description: 'Open-source photography booking web application. System for managing bookings, portfolios, and photographer-client interactions.',
    technologies: ['Laravel', 'Blade', 'JavaScript'],
    status: 'Completed',
    github: 'https://github.com/mjaya69703/www.arpotret.biz.id',
    demo: 'https://arpotret.idev-fun.org',
  },
  {
    name: 'Laraflare',
    description: 'Laravel Domain Manager with Cloudflare API. A tool for managing domains and DNS records through Cloudflare integration.',
    technologies: ['Laravel', 'Blade', 'Cloudflare API'],
    status: 'Completed',
    github: 'https://github.com/mjaya69703/laraflare',
    demo: null,
  },
  {
    name: 'Homelab Infrastructure',
    description: 'Self-hosted infrastructure on a Mini PC running Proxmox VE with LXC containers. Hosts 5+ web apps, monitoring stack (Grafana + Prometheus), Docker services, and centralized database — all exposed via Cloudflare Tunnel with zero open ports.',
    technologies: ['Proxmox', 'Docker', 'Nginx', 'Cloudflare Tunnel', 'Grafana', 'MariaDB'],
    status: 'Active',
    github: null,
    demo: null,
    link: '/homelab/',
    linkLabel: 'View Setup',
  },
];

const statusColor: Record<string, string> = {
  Active: 'badge-success',
  Completed: 'badge-primary',
  Exploring: 'badge-warning',
};
---

<BaseLayout title="Projects - AscendKyo.dev" description="Projects built by Muhamad Jaya Kusuma (AscendKyo)">
  <section class="px-6 py-24">
    <div class="mx-auto max-w-5xl">
      <h1 class="text-3xl font-bold tracking-tight">Projects</h1>
      <p class="mt-2 text-muted">What has been built and what technologies were used</p>

      <div class="mt-10 grid gap-6 md:grid-cols-2">
        {projects.map((project) => (
          <div class="card flex flex-col">
            <div class="flex items-start justify-between gap-3">
              <h2 class="text-lg font-semibold">{project.name}</h2>
              <span class:list={['shrink-0', 'badge', statusColor[project.status] ?? 'badge']}>
                {project.status}
              </span>
            </div>
            <p class="mt-3 text-sm text-muted leading-relaxed">{project.description}</p>
            <div class="mt-4 flex flex-wrap gap-2">
              {project.technologies.map((tech) => (
                <span class="badge mono text-xs">{tech}</span>
              ))}
            </div>
            <div class="mt-auto flex items-center gap-4 pt-6">
              {project.github && (
                <a
                  href={project.github}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-1.5 text-sm text-muted transition-colors hover:text-text"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg>
                  Source
                </a>
              )}
              {project.demo && (
                <a
                  href={project.demo}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-1.5 text-sm text-muted transition-colors hover:text-text"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h6v6"></path><path d="M10 14 21 3"></path><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path></svg>
                  Demo
                </a>
              )}
              {project.link && (
                <a
                  href={project.link}
                  class="flex items-center gap-1.5 text-sm text-muted transition-colors hover:text-text"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h6v6"></path><path d="M10 14 21 3"></path><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path></svg>
                  {project.linkLabel ?? 'Details'}
                </a>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
