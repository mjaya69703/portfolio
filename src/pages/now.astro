---
import BaseLayout from '../layouts/BaseLayout.astro';
import { profile } from '../data/profile';
---

<BaseLayout title="Now - AscendKyo.dev" description="Current snapshot of what AscendKyo is working on, learning, and interested in">
  <section class="px-6 py-24">
    <div class="mx-auto max-w-5xl">
      <div class="flex items-start justify-between gap-4">
        <div>
          <h1 class="text-3xl font-bold tracking-tight">Now</h1>
          <p class="mt-2 text-muted">What I'm focused on right now</p>
        </div>
        <p class="mono text-xs text-muted shrink-0 mt-2">Last updated: June 2026</p>
      </div>

      <p class="mt-6 text-sm text-muted max-w-3xl leading-relaxed">
        This is a <a href="https://nownownow.com" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">/now page</a>. It tells you what I'm up to at this point in my life.
      </p>

      <!-- Current Work -->
      <div class="mt-10">
        <h2 class="section-title flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><rect width="20" height="14" x="2" y="7" rx="2" ry="2"></rect><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path></svg>
          Current Work
        </h2>
        <div class="mt-4 card">
          <p class="text-sm text-muted leading-relaxed">
            Currently working as <strong class="text-text">{profile.role}</strong> at <strong class="text-text">{profile.company}</strong>. Responsible for monitoring infrastructure, managing cloud resources, and ensuring system reliability.
          </p>
        </div>
      </div>

      <!-- Current Learning -->
      <div class="mt-10">
        <h2 class="section-title flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg>
          Current Learning
        </h2>
        <div class="mt-4 space-y-3">
          <div class="card flex items-center gap-3">
            <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-primary/10 text-primary shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"></path><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"></path><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"></path><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"></path></svg>
            </div>
            <div>
              <p class="text-sm font-medium">Kubernetes</p>
              <p class="text-xs text-muted">Container orchestration and cluster management</p>
            </div>
          </div>
          <div class="card flex items-center gap-3">
            <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-primary/10 text-primary shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"></path><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path></svg>
            </div>
            <div>
              <p class="text-sm font-medium">Infrastructure Automation</p>
              <p class="text-xs text-muted">Terraform, Ansible, and IaC practices</p>
            </div>
          </div>
          <div class="card flex items-center gap-3">
            <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-primary/10 text-primary shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8V4H8"></path><rect width="16" height="12" x="4" y="8" rx="2"></rect><path d="M2 14h2"></path><path d="M20 14h2"></path><path d="M15 13v2"></path><path d="M9 13v2"></path></svg>
            </div>
            <div>
              <p class="text-sm font-medium">AI Agents</p>
              <p class="text-xs text-muted">Building and experimenting with AI-powered workflows</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Current Projects -->
      <div class="mt-10">
        <h2 class="section-title flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path></svg>
          Current Projects
        </h2>
        <div class="mt-4 space-y-3">
          <a href="/projects/" class="card block flex items-center justify-between">
            <div class="flex items-center gap-3">
              <div class="h-2.5 w-2.5 rounded-full bg-success"></div>
              <span class="text-sm font-medium">NexaCampus</span>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted"><path d="m9 18 6-6-6-6"></path></svg>
          </a>
          <a href="/homelab/" class="card block flex items-center justify-between">
            <div class="flex items-center gap-3">
              <div class="h-2.5 w-2.5 rounded-full bg-warning"></div>
              <span class="text-sm font-medium">Homelab Improvements</span>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted"><path d="m9 18 6-6-6-6"></path></svg>
          </a>
          <div class="card flex items-center justify-between">
            <div class="flex items-center gap-3">
              <div class="h-2.5 w-2.5 rounded-full bg-success"></div>
              <span class="text-sm font-medium">AscendKyo.dev</span>
            </div>
            <span class="badge text-xs">This site</span>
          </div>
        </div>
      </div>

      <!-- Current Interests -->
      <div class="mt-10">
        <h2 class="section-title flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.74 0-3 .41-4.5 1.5C10.5 3.41 9.24 3 7.5 3A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"></path></svg>
          Current Interests
        </h2>
        <div class="mt-4 flex flex-wrap gap-3">
          <span class="badge badge-primary">Cloud Infrastructure</span>
          <span class="badge badge-primary">Monitoring Systems</span>
          <span class="badge badge-primary">Automation</span>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
