---
import NavLink from './NavLink.astro';
import { profile } from '../data/profile';

const navItems = [
  { href: '/', label: 'Home' },
  { href: '/projects/', label: 'Projects' },
  { href: '/homelab/', label: 'Homelab' },
  { href: '/blog/', label: 'Blog' },
  { href: '/resume/', label: 'Resume' },
  { href: '/now/', label: 'Now' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 border-b border-border bg-bg/80 backdrop-blur-md">
  <nav class="mx-auto flex h-14 max-w-5xl items-center justify-between px-6">
    <a href="/" class="text-sm font-bold tracking-tight text-text mono" aria-label={profile.domain}>
      {profile.alias}<span class="text-primary">.dev</span>
    </a>

    <div class="hidden items-center gap-6 md:flex">
      {navItems.map((item) => (
        <NavLink href={item.href} label={item.label} />
      ))}
    </div>

    <div class="flex items-center gap-4">
      <a
        href={profile.links.github}
        target="_blank"
        rel="noopener noreferrer"
        class="text-muted transition-colors duration-150 hover:text-text"
        aria-label="GitHub"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg>
      </a>
      <a
        href={profile.links.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="text-muted transition-colors duration-150 hover:text-text"
        aria-label="LinkedIn"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect width="4" height="12" x="2" y="9"></rect><circle cx="4" cy="4" r="2"></circle></svg>
      </a>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="text-muted hover:text-text md:hidden"
        aria-label="Toggle menu"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"></line><line x1="4" x2="20" y1="6" y2="6"></line><line x1="4" x2="20" y1="18" y2="18"></line></svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden border-t border-border md:hidden">
    <div class="mx-auto flex max-w-5xl flex-col gap-4 px-6 py-4">
      {navItems.map((item) => (
        <NavLink href={item.href} label={item.label} />
      ))}
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
